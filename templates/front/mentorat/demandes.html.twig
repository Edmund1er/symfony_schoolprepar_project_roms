{% extends 'front/base.html.twig' %}

{% block title %}Mes demandes de mentorat - SchoolPrepar{% endblock %}

{% block body %}
<style>
    .page-demandes {
        background: #f0f2f5;
        padding: 40px 0;
        min-height: 100vh;
    }
    .btn-trouver-mentor {
        background: #9ddeac;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 8px 20px;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }
    .btn-trouver-mentor:hover {
        background: #007bff;
        transform: translateY(-2px);
        color: white;
    }
    .table-custom {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .table-custom thead th {
        background: #007bff;
        color: white;
        border: none;
        padding: 12px 15px;
    }
    .badge-warning-custom {
        background: #ffc107;
        color: #333;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
    }
    .badge-success-custom {
        background: #28a745;
        color: white;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
    }
    .badge-danger-custom {
        background: #dc3545;
        color: white;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
    }
</style>

<div class="page-demandes">
    <div class="container py-5">
        <div class="row">
            <div class="col-md-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h3">Mes demandes de mentorat</h1>
                    <a href="{{ path('mentorat_index') }}" class="btn-trouver-mentor">Trouver un mentor</a>
                </div>

                {% if demandes|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-bordered table-custom">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Mentor</th>
                                    <th>Message</th>
                                    <th>Date demande</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for demande in demandes %}
                                <tr>
                                    <td>{{ loop.index }}</td>
                                    <td>
                                        <strong>{{ demande.mentor.nom }} {{ demande.mentor.prenom }}</strong>
                                        {% if demande.mentor.specialite %}
                                            <br><small class="text-muted">{{ demande.mentor.specialite }}</small>
                                        {% endif %}
                                     </td>
                                    <td>{{ demande.message|slice(0, 80) }}{% if demande.message|length > 80 %}...{% endif %} </td>
                                    <td>{{ demande.demandeLe|date('d/m/Y H:i') }} </td>
                                    <td>
                                        {% if demande.statut == 'en_attente' %}
                                            <span class="badge-warning-custom">En attente</span>
                                        {% elseif demande.statut == 'accepte' %}
                                            <span class="badge-success-custom">Accepte</span>
                                        {% elseif demande.statut == 'refuse' %}
                                            <span class="badge-danger-custom">Refuse</span>
                                        {% endif %}
                                     </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-info text-center">
                        Vous n'avez envoye aucune demande de mentorat.
                        <br><br>
                        <a href="{{ path('mentorat_index') }}" class="btn-trouver-mentor">Trouver un mentor</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}