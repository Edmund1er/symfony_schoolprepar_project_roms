{% extends 'front/base.html.twig' %}

{% block title %}{{ categorie.nom }} - Forum{% endblock %}

{% block body %}
<style>
    .page-forum-categorie {
        background: #f0f2f5;
        padding: 40px 0;
        min-height: 100vh;
    }
    .sujet-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 15px;
        transition: 0.3s;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .sujet-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }
    .sujet-epingle {
        border-left: 4px solid #ffc107;
    }
    .sujet-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #333;
    }
    .sujet-title a {
        color: #333;
        text-decoration: none;
    }
    .sujet-title a:hover {
        color: #007bff;
    }
    .sujet-meta {
        font-size: 0.8rem;
        color: #6c757d;
    }
    .btn-retour {
        background: #17a2b8;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 8px 20px;
        margin-bottom: 20px;
        display: inline-block;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-retour:hover {
        background: #138496;
        transform: translateY(-2px);
        color: white;
    }
    .btn-new-sujet {
        background: #28a745;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 8px 20px;
        margin-bottom: 20px;
        float: right;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-new-sujet:hover {
        background: #007bff;
        transform: translateY(-2px);
        color: white;
    }
    .badge-epingle {
        background: #ffc107;
        color: #333;
        padding: 3px 8px;
        border-radius: 20px;
        font-size: 0.7rem;
    }
</style>

<div class="page-forum-categorie">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="{{ path('forum_index') }}" class="btn-retour">Retour au forum</a>
            {% if app.user %}
                <a href="{{ path('forum_sujet_new') }}" class="btn-new-sujet">Nouveau sujet</a>
            {% endif %}
        </div>

        <div class="clearfix"></div>

        <div class="mb-4">
            <h2>{{ categorie.nom }}</h2>
            <p class="text-muted">{{ categorie.description }}</p>
        </div>

        <div class="row">
            <div class="col-md-12">
                {% for sujet in sujets %}
                    <div class="sujet-card {{ sujet.isEpingle ? 'sujet-epingle' : '' }}">
                        <div class="row align-items-center">
                            <div class="col-md-7">
                                {% if sujet.isEpingle %}
                                    <span class="badge-epingle">Epingle</span>
                                {% endif %}
                                <h5 class="sujet-title">
                                    <a href="{{ path('forum_sujet_show', {'id': sujet.id}) }}">{{ sujet.titre }}</a>
                                </h5>
                                <div class="sujet-meta">
                                    Par <strong>{{ sujet.auteur.nom }} {{ sujet.auteur.prenom }}</strong>
                                    <span class="mx-2"></span>
                                    {{ sujet.dateCreation|date('d/m/Y H:i') }}
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                {{ sujet.messages|length }}
                                <br><small class="text-muted">reponses</small>
                            </div>
                            <div class="col-md-3">
                                {% if sujet.dateDernierMessage %}
                                    <small class="text-muted">{{ sujet.dateDernierMessage|date('d/m/Y H:i') }}</small>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-info text-center">
                        Aucun sujet dans cette categorie.
                        <br><br>
                        <a href="{{ path('forum_sujet_new') }}" class="btn-new-sujet" style="float: none; display: inline-block;">Creer le premier sujet</a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}