{% extends 'front/base.html.twig' %}

{% block title %}Nouveau sujet - Forum{% endblock %}

{% block body %}
<style>
    .page-forum-new {
        background: #f0f2f5;
        padding: 40px 0;
        min-height: 100vh;
    }
    .form-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .form-control {
        border-radius: 15px;
        border: 1px solid #e0e0e0;
        padding: 12px 15px;
    }
    .form-control:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 3px rgba(0,123,255,0.1);
    }
    .btn-publier {
        background: #88d199;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 12px 30px;
        font-weight: 600;
        transition: 0.3s;
        cursor: pointer;
    }
    .btn-publier:hover {
        background: #007bff;
        transform: scale(1.02);
    }
    .btn-annuler {
        background: #97bfc5;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 12px 30px;
        margin-left: 15px;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-annuler:hover {
        background: #138496;
        transform: translateY(-2px);
        color: white;
    }
</style>

<div class="page-forum-new">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="form-card">
                    <h3 class="text-center mb-4">Creer un nouveau sujet</h3>

                    <form method="post">
                        <div class="form-group">
                            <label>Categorie</label>
                            <select name="categorie" class="form-control" required>
                                <option value="">Selectionnez une categorie</option>
                                {% for categorie in categories %}
                                    <option value="{{ categorie.id }}">{{ categorie.nom }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Titre du sujet</label>
                            <input type="text" name="titre" class="form-control" placeholder="Ex: Question sur l'orientation" required>
                        </div>

                        <div class="form-group">
                            <label>Contenu</label>
                            <textarea name="contenu" class="form-control" rows="8" placeholder="Decrivez votre question ou votre sujet..." required></textarea>
                        </div>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn-publier">Publier le sujet</button>
                            <a href="{{ path('forum_index') }}" class="btn-annuler">Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}