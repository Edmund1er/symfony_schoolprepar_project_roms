{% extends 'front/base.html.twig' %}

{% block title %}Forum - SchoolPrepar{% endblock %}

{% block body %}
<style>
    .page-forum {
        background: #f0f2f5;
        padding: 40px 0;
        min-height: 100vh;
    }
    .forum-category {
        background: white;
        border-radius: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        height: 100%;
        cursor: pointer;
    }
    .forum-category:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    }
    .forum-category .card-body {
        padding: 25px;
    }
    .section-title {
        font-size: 1.8rem;
        margin-bottom: 30px;
        text-align: center;
        color: #333;
        font-weight: 500;
    }
    .btn-new-sujet {
        background: #8ec49a;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 10px 25px;
        margin-bottom: 20px;
        display: inline-block;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-new-sujet:hover {
        background: #007bff;
        transform: translateY(-2px);
        color: white;
    }
</style>

<div class="page-forum">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title mb-0">Forum communautaire</h2>
            {% if app.user %}
                <a href="{{ path('forum_sujet_new') }}" class="btn-new-sujet">
                    Nouveau sujet
                </a>
            {% endif %}
        </div>

        <div class="row">
            {% for categorie in categories %}
                <div class="col-md-4 mb-4">
                    <div class="forum-category" onclick="window.location.href='{{ path('forum_categorie', {'id': categorie.id}) }}'">
                        <div class="card-body">
                            <i class="fa fa-folder-open-o fa-3x text-primary mb-3"></i>
                            <h5 class="card-title">{{ categorie.nom }}</h5>
                            <p class="card-text text-muted">{{ categorie.description }}</p>
                            <hr>
                            <small class="text-muted">
                                <i class="fa fa-comments"></i> {{ categorie.sujets|length }} sujets
                            </small>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info text-center">Aucune categorie disponible.</div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}