{% extends 'front/base.html.twig' %}

{% block title %}{{ sujet.titre }} - Forum{% endblock %}

{% block body %}
<style>
    .page-forum-sujet {
        background: #f0f2f5;
        padding: 40px 0;
        min-height: 100vh;
    }
    .message-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .message-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
    }
    .message-author {
        font-weight: 600;
        color: #007bff;
    }
    .message-date {
        font-size: 0.75rem;
        color: #6c757d;
    }
    .message-content {
        line-height: 1.6;
        color: #333;
    }
    .badge-mentor {
        background: #83ca94;
        color: white;
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 20px;
        margin-left: 10px;
    }
    .badge-admin {
        background: #dc3545;
        color: white;
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 20px;
        margin-left: 10px;
    }
    .reponse-form {
        background: white;
        border-radius: 20px;
        padding: 25px;
        margin-top: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }
    .btn-retour {
        background: #8fbcc3;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 8px 20px;
        margin-bottom: 20px;
        display: inline-block;
        text-decoration: none;
        transition: 0.3s;
    }
    .btn-retour:hover {
        background: #138496;
        transform: translateY(-2px);
        color: white;
    }
    .btn-envoyer {
        background: #b4edc1;
        color: white;
        border: none;
        border-radius: 40px;
        padding: 10px 30px;
        transition: 0.3s;
        cursor: pointer;
    }
    .btn-envoyer:hover {
        background: #007bff;
        transform: translateY(-2px);
    }
    .form-control {
        border-radius: 15px;
        border: 1px solid #e0e0e0;
        padding: 12px 15px;
    }
    .form-control:focus {
        border-color: #28a745;
        box-shadow: 0 0 0 3px rgba(40,167,69,0.1);
    }
</style>

<div class="page-forum-sujet">
    <div class="container">
        <a href="{{ path('forum_categorie', {'id': sujet.categorie.id}) }}" class="btn-retour">Retour à {{ sujet.categorie.nom }}</a>

        <!-- Message initial -->
        <div class="message-card">
            <div class="message-header">
                <div>
                    <span class="message-author">{{ sujet.auteur.nom }} {{ sujet.auteur.prenom }}</span>
                    {% if 'ROLE_MENTOR' in sujet.auteur.role %}
                        <span class="badge-mentor">Mentor</span>
                    {% elseif 'ROLE_ADMIN' in sujet.auteur.role %}
                        <span class="badge-admin">Admin</span>
                    {% endif %}
                </div>
                <div class="message-date">{{ sujet.dateCreation|date('d/m/Y H:i') }}</div>
            </div>
            <div class="message-content">
                <h4>{{ sujet.titre }}</h4>
                <p>{{ sujet.contenu|nl2br }}</p>
            </div>
        </div>

        <!-- Liste des reponses -->
        <h5 class="mb-3">{{ sujet.messages|length }} reponse(s)</h5>

        {% for message in sujet.messages %}
            <div class="message-card">
                <div class="message-header">
                    <div>
                        <span class="message-author">{{ message.auteur.nom }} {{ message.auteur.prenom }}</span>
                        {% if 'ROLE_MENTOR' in message.auteur.role %}
                            <span class="badge-mentor">Mentor</span>
                        {% elseif 'ROLE_ADMIN' in message.auteur.role %}
                            <span class="badge-admin">Admin</span>
                        {% endif %}
                    </div>
                    <div class="message-date">{{ message.dateCreation|date('d/m/Y H:i') }}</div>
                </div>
                <div class="message-content">{{ message.contenu|nl2br }}</div>
            </div>
        {% endfor %}

        <!-- Formulaire pour repondre -->
        {% if app.user %}
            <div class="reponse-form">
                <h5>Votre reponse</h5>
                <form method="post" action="{{ path('forum_sujet_repondre', {'id': sujet.id}) }}">
                    <div class="form-group">
                        <textarea name="contenu" class="form-control" rows="5" placeholder="Ecrivez votre reponse..." required></textarea>
                    </div>
                    <button type="submit" class="btn-envoyer">Envoyer la reponse</button>
                </form>
            </div>
        {% else %}
            <div class="alert alert-info text-center mt-4">
                <a href="{{ path('app_login') }}">Connectez-vous</a> pour participer a la discussion.
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}