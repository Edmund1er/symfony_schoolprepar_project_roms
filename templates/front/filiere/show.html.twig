{% extends 'front/base.html.twig' %}

{% block title %}{{ filiere.nom }} - SchoolPrepar{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-header-overlay">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <header class="entry-header">
                        <h1 class="entry-title">{{ filiere.nom }}</h1>
                    </header>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="breadcrumbs">
                <ul class="flex flex-wrap align-items-center p-0 m-0">
                    <li><a href="{{ path('front_home') }}"><i class="fa fa-home"></i> Accueil</a></li>
                    <li><a href="{{ path('filiere_index') }}">Filières</a></li>
                    <li>{{ filiere.nom }}</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="text-center mb-4">
                        {% if filiere.image %}
                            <img src="{{ asset('assets/admin/images/filieres/' ~ filiere.image) }}" 
                                 alt="{{ filiere.nom }}" 
                                 style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%;">
                        {% else %}
                            <i class="fa fa-graduation-cap fa-6x text-primary"></i>
                        {% endif %}
                    </div>
                    <h2>Description</h2>
                    <p>{{ filiere.description }}</p>
                    
                    <h2>Objectifs de la formation</h2>
                    <ul>
                        <li>Maîtrise des concepts fondamentaux de la filière {{ filiere.nom }}</li>
                        <li>Développement de compétences pratiques et théoriques</li>
                        <li>Préparation aux certifications professionnelles</li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-body">
                    <h5>Informations</h5>
                    <ul class="list-unstyled">
                        <li><strong>Code:</strong> FIL-{{ '%02d'|format(filiere.id) }}</li>
                        <li><strong>Durée:</strong> 3 ans (Licence)</li>
                        <li><strong>Prix:</strong> Gratuit</li>
                    </ul>
                </div>
            </div>
            
            <div class="card">
                <div class="card-body">
                    <h5>Liens utiles</h5>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('filiere_index') }}">← Toutes les filières</a></li>
                        <li><a href="{{ path('front_home') }}">← Retour à l'accueil</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}