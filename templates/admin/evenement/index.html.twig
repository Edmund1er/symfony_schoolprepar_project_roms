{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des événements{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Gestion des événements</h5>
                    <p class="m-b-0">Gérer les événements et webinaires</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#">Événements</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>Liste des événements</h5>
                        <button type="button" class="btn btn-primary float-right" data-toggle="modal" data-target="#addModal">
                            <i class="fa fa-plus"></i> Nouvel événement
                        </button>
                    </div>
                    <div class="card-block">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover">
                                <thead class="thead-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Titre</th>
                                        <th>Date</th>
                                        <th>Lieu</th>
                                        <th>Participants</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% set offset = pagination.getCurrentPageNumber() * pagination.getItemNumberPerPage() - pagination.getItemNumberPerPage() %}
                                {% for evenement in pagination %}
                                    <tr>
                                        <td>{{ offset + loop.index }}</td>
                                        <td><strong>{{ evenement.titre }}</strong></td>
                                        <td>{{ evenement.date|date('d/m/Y H:i') }}</td>
                                        <td>{{ evenement.lieu }}</td>
                                        <td><span class="badge badge-secondary">{{ evenement.participants|length }} inscrit(s)</span></td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-warning" data-toggle="modal" data-target="#editModal{{ evenement.id }}">
                                                <i class="fa fa-pencil"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" data-toggle="modal" data-target="#deleteModal{{ evenement.id }}">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="6" class="text-center">Aucun événement</td></tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="row mt-3">
                            <div class="col-sm-6">
                                <small class="text-muted">Affichage de {{ pagination.getCurrentPageNumber() * pagination.getItemNumberPerPage() - pagination.getItemNumberPerPage() + 1 }} à {{ min(pagination.getCurrentPageNumber() * pagination.getItemNumberPerPage(), pagination.getTotalItemCount()) }} sur {{ pagination.getTotalItemCount() }} événements</small>
                            </div>
                            <div class="col-sm-6 text-right">
                                {{ knp_pagination_render(pagination) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL AJOUT -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('app_admin_evenement_new') }}">
                <div class="modal-header">
                    <h5 class="modal-title">Nouvel événement</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Titre</label>
                        <input type="text" name="titre" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>Date et heure</label>
                        <input type="datetime-local" name="date" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>Lieu</label>
                        <input type="text" name="lieu" class="form-control">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODALS EDITION & SUPPRESSION -->
{% for evenement in pagination %}
<div class="modal fade" id="editModal{{ evenement.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('app_admin_evenement_edit', {'id': evenement.id}) }}">
                <div class="modal-header">
                    <h5 class="modal-title">Modifier {{ evenement.titre }}</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Titre</label>
                        <input type="text" name="titre" class="form-control" value="{{ evenement.titre }}" required>
                    </div>
                    <div class="form-group">
                        <label>Date et heure</label>
                        <input type="datetime-local" name="date" class="form-control" value="{{ evenement.date|date('Y-m-d\\TH:i') }}" required>
                    </div>
                    <div class="form-group">
                        <label>Lieu</label>
                        <input type="text" name="lieu" class="form-control" value="{{ evenement.lieu }}">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary">Modifier</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal{{ evenement.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('app_admin_evenement_delete', {'id': evenement.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <p>Supprimer l'événement <strong>{{ evenement.titre }}</strong> ?</p>
                    <p class="text-danger">Action irréversible.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-danger">Supprimer</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}