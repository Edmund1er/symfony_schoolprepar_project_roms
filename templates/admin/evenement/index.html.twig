{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Événements{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Liste des Événements</h5>
                    <p class="m-b-0">Gérer les événements de la plateforme</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#">Événements</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>Événements programmés</h5>
                        <a href="{{ path('app_admin_evenement_new') }}" class="btn btn-primary float-right">
                            <i class="fa fa-plus"></i> Ajouter un événement
                        </a>
                    </div>
                    <div class="card-block">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 5%">#</th>
                                        <th style="width: 10%">APERÇU</th>
                                        <th style="width: 25%">TITRE</th>
                                        <th style="width: 20%">DATE</th>
                                        <th style="width: 20%">LIEU</th>
                                        <th style="width: 20%">ACTIONS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for evenement in evenements %}
                                    <tr>
                                        <td class="text-center">{{ loop.index }}</td>
                                        <td class="text-center">
                                            <div class="avatar">
                                                <i class="fa fa-calendar fa-2x text-c-yellow"></i>
                                            </div>
                                        </td>
                                        <td><strong>{{ evenement.titre }}</strong></td>
                                        <td>{{ evenement.date ? evenement.date|date('d/m/Y H:i') : '' }}</td>
                                        <td>{{ evenement.lieu }}</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('app_admin_evenement_show', {'id': evenement.id}) }}" 
                                                   class="btn btn-sm btn-info" title="Voir">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                                <a href="{{ path('app_admin_evenement_edit', {'id': evenement.id}) }}" 
                                                   class="btn btn-sm btn-warning" title="Modifier">
                                                    <i class="fa fa-pencil"></i>
                                                </a>
                                                <button type="button" 
                                                        class="btn btn-sm btn-danger" 
                                                        data-toggle="modal" 
                                                        data-target="#deleteModalEvent{{ evenement.id }}"
                                                        title="Supprimer">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>
                                            
                                            <div class="modal fade" id="deleteModalEvent{{ evenement.id }}" tabindex="-1" role="dialog">
                                                <div class="modal-dialog" role="document">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Confirmer la suppression</h5>
                                                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p>Êtes-vous sûr de vouloir supprimer l'événement <strong>{{ evenement.titre }}</strong> ?</p>
                                                            <p class="text-danger">Cette action est irréversible.</p>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Annuler</button>
                                                            <form method="post" action="{{ path('app_admin_evenement_delete', {'id': evenement.id}) }}">
                                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                                                                <button type="submit" class="btn btn-danger">Confirmer</button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                     </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center">Aucun événement trouvé</td>
                                     </tr>
                                {% endfor %}
                                </tbody>
                             </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}