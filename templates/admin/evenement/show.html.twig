{% extends 'admin/base.html.twig' %}

{% block title %}Détail Événement{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Détail Événement</h5>
                    <p class="m-b-0">Consultation des informations d'un événement</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_evenement_index') }}">Événements</a></li>
                    <li class="breadcrumb-item"><a href="#">{{ evenement.titre }}</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>{{ evenement.titre }}</h5>
                        <div class="card-header-right">
                            <a href="{{ path('app_admin_evenement_edit', {'id': evenement.id}) }}" class="btn btn-warning btn-sm">
                                <i class="fa fa-pencil"></i> Modifier
                            </a>
                            <a href="{{ path('app_admin_evenement_index') }}" class="btn btn-secondary btn-sm">
                                <i class="fa fa-arrow-left"></i> Retour
                            </a>
                        </div>
                    </div>
                    <div class="card-block">
                        <div class="row">
                            <div class="col-md-3 text-center">
                                <div class="avatar-lg">
                                    <i class="fa fa-calendar-check-o fa-5x text-c-yellow"></i>
                                </div>
                                <h4 class="mt-3">{{ evenement.titre }}</h4>
                            </div>
                            <div class="col-md-9">
                                <div class="info-group">
                                    <label>Titre</label>
                                    <p>{{ evenement.titre }}</p>
                                </div>
                                <div class="info-group">
                                    <label>Date</label>
                                    <p>{{ evenement.date ? evenement.date|date('d/m/Y H:i') : '' }}</p>
                                </div>
                                <div class="info-group">
                                    <label>Lieu</label>
                                    <p>{{ evenement.lieu }}</p>
                                </div>
                                <div class="info-group">
                                    <label>Participants</label>
                                    <p>
                                        {% for participant in evenement.participants %}
                                            <span class="badge badge-info">{{ participant.nom }} {{ participant.prenom }}</span>
                                        {% else %}
                                            Aucun participant
                                        {% endfor %}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        {{ include('admin/evenement/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}