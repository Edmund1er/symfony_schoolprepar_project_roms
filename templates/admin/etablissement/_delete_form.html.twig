<form method="post" action="{{ path('app_admin_etablissement_delete', {'id': etablissement.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet établissement ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etablissement.id) }}">
    <button class="btn btn-danger">🗑️ Supprimer</button>
</form>