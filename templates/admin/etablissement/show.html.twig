{% extends 'admin/base.html.twig' %}

{% block title %}Détail Établissement{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Détail Établissement</h5>
                    <p class="m-b-0">Consultation des informations</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_etablissement_index') }}">Établissements</a></li>
                    <li class="breadcrumb-item"><a href="#">Détail</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>{{ etablissement.nom }}</h5>
                        <div class="card-header-right">
                            <a href="{{ path('app_admin_etablissement_edit', {'id': etablissement.id}) }}" class="btn btn-warning btn-sm">✏️ Modifier</a>
                            <a href="{{ path('app_admin_etablissement_index') }}" class="btn btn-secondary btn-sm">↩️ Retour</a>
                        </div>
                    </div>
                    <div class="card-block">
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width: 200px;">Id</th>
                                    <td>{{ etablissement.id }}</td>
                                </tr>
                                <tr>
                                    <th>Nom</th>
                                    <td>{{ etablissement.nom }}</td>
                                </tr>
                                <tr>
                                    <th>Adresse</th>
                                    <td>{{ etablissement.adresse }}</td>
                                </tr>
                                <tr>
                                    <th>Email</th>
                                    <td>{{ etablissement.email }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        {{ include('admin/etablissement/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}