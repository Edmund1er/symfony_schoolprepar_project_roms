<form method="post" action="{{ path('app_admin_filiere_delete', {'id': filiere.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette filière ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">
    <button class="btn btn-danger">
        <i class="fa fa-trash"></i> Supprimer
    </button>
</form>