{% extends 'admin/base.html.twig' %}

{% block title %}Détail Utilisateur{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Détail Utilisateur</h5>
                    <p class="m-b-0">Consultation des informations d'un utilisateur</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_utilisateur_index') }}">Utilisateurs</a></li>
                    <li class="breadcrumb-item"><a href="#">{{ user.prenom }} {{ user.nom }}</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>{{ user.prenom }} {{ user.nom }}</h5>
                        <div class="card-header-right">
                            <a href="{{ path('app_admin_utilisateur_edit', {'id': user.id}) }}" class="btn btn-warning btn-sm">
                                <i class="fa fa-pencil"></i> Modifier
                            </a>
                            <a href="{{ path('app_admin_utilisateur_index') }}" class="btn btn-secondary btn-sm">
                                <i class="fa fa-arrow-left"></i> Retour
                            </a>
                        </div>
                    </div>
                    <div class="card-block">
                        <div class="row">
                            <div class="col-md-3 text-center">
                                <div class="avatar-lg">
                                    <i class="fa fa-user-circle fa-5x text-c-blue"></i>
                                </div>
                                <h4 class="mt-3">{{ user.prenom }} {{ user.nom }}</h4>
                                <p class="text-muted">ID: #{{ user.id }}</p>
                            </div>
                            <div class="col-md-9">
                                <div class="info-group">
                                    <label>Nom complet</label>
                                    <p>{{ user.prenom }} {{ user.nom }}</p>
                                </div>
                                <div class="info-group">
                                    <label>Email</label>
                                    <p>{{ user.email }}</p>
                                </div>
                                <div class="info-group">
                                    <label>Rôle(s)</label>
                                    <p>
                                        {% for role in user.role %}
                                            <span class="badge badge-info">{{ role }}</span>
                                        {% endfor %}
                                    </p>
                                </div>
                                <div class="info-group">
                                    <label>Filière</label>
                                    <p>{{ user.filiere ? user.filiere.nom : 'Non assigné' }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        {{ include('admin/utilisateur/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}