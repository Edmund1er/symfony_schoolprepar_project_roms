{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="page-header-title">
                    <h5 class="m-b-10">Utilisateurs</h5>
                    <p class="m-b-0">Gestion des utilisateurs de la plateforme</p>
                </div>
            </div>
            <div class="col-md-4">
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}"><i class="fa fa-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#">Utilisateurs</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="pcoded-inner-content">
    <div class="main-body">
        <div class="page-wrapper">
            <div class="page-body">
                <div class="card">
                    <div class="card-header">
                        <h5>Liste des utilisateurs</h5>
                        <a href="{{ path('app_admin_utilisateur_new') }}" class="btn btn-primary float-right">+ Nouvel utilisateur</a>
                    </div>
                    <div class="card-block">
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Id</th>
                                    <th>Nom</th>
                                    <th>Prénom</th>
                                    <th>Email</th>
                                    <th>Rôle(s)</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for user in users %}
                                <tr>
                                    <td>{{ user.id }}</td>
                                    <td>{{ user.nom }}</td>
                                    <td>{{ user.prenom }}</td>
                                    <td>{{ user.email }}</td>
                                    <td>
                                        {% for role in user.role %}
                                            <span class="badge badge-info">{{ role }}</span>
                                        {% else %}
                                            <span class="badge badge-secondary">Aucun</span>
                                        {% endfor %}
                                    </td>
                                    <td>
                                        <a href="{{ path('app_admin_utilisateur_show', {'id': user.id}) }}" class="btn btn-sm btn-info">Voir</a>
                                        <a href="{{ path('app_admin_utilisateur_edit', {'id': user.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center">Aucun utilisateur trouvé</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}